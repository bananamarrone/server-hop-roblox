local SCOUT_FILE = "BSH_scout.json"

local function log(msg)
    print(LOG_PREFIX .. " " .. msg)
end

local function safeRead(f)
    if not (isfile and isfile(f)) then return nil end
    local ok, d = pcall(readfile, f)
    return ok and d or nil
end

local function safeWrite(f, d)
    pcall(function() if writefile then writefile(f, d) end end)
end

local scoutState = {hopCount = 0, found = 0}
local function saveScout()
    local ok, enc = pcall(function() return HttpService:JSONEncode(scoutState) end)
    if ok then safeWrite(SCOUT_FILE, enc) end
end
local function loadScout()
    local raw = safeRead(SCOUT_FILE); if not raw then return end
    local ok, d = pcall(function() return HttpService:JSONDecode(raw) end)
    if ok and type(d) == "table" then
        if type(d.hopCount) == "number" then scoutState.hopCount = d.hopCount end
        if type(d.found)    == "number" then scoutState.found    = d.found    end
    end
end
loadScout()

local SCRIPT_SOURCE
pcall(function()
    local raw = safeRead("BSH_scout_run.lua")
    if raw then SCRIPT_SOURCE = raw end
end)
local function queueSelf()
    if not SCRIPT_SOURCE then return end
    pcall(function() if queue_on_teleport then queue_on_teleport(SCRIPT_SOURCE) end end)
    pcall(function() if syn and syn.queue_on_teleport then syn.queue_on_teleport(SCRIPT_SOURCE) end end)
    pcall(function() if fluxus and fluxus.queue_on_teleport then fluxus.queue_on_teleport(SCRIPT_SOURCE) end end)
end

local function fmtVal(n)
    if not n or n <= 0 then return "0" end
    if n >= 1e12 then return string.format("%.2fT", n/1e12)
    elseif n >= 1e9  then return string.format("%.2fB", n/1e9)
    elseif n >= 1e6  then return string.format("%.2fM", n/1e6)
    elseif n >= 1e3  then return string.format("%.1fK", n/1e3)
    else return tostring(math.floor(n)) end
end

local function parseValue(raw)
    if not raw or raw == "" then return 0 end
    local t = raw:gsub("^%s*%$?%s*", ""):lower():gsub("%s+", "")
    if t == "" then return 0 end
    local n, s = t:match("^([%d%.]+)([kmbt]?)$")
    n = tonumber(n)
    if not n then return 0 end
    if     s == "k" then n = n * 1e3
    elseif s == "m" then n = n * 1e6
    elseif s == "b" then n = n * 1e9
    elseif s == "t" then n = n * 1e12 end
    return n
end

local function sendWebhook(brainrotName, valueMps, rawText, jobId, playerCount)
    local valueStr = fmtVal(valueMps) .. "/s"
    local joinCmd  = string.format("game:GetService('TeleportService'):TeleportToPlaceInstance(%d, '%s')", PlaceId, jobId)
    local payload  = {
        username   = "Banana Notifier",
        avatar_url = "https://upload.wikimedia.org/wikipedia/commons/thumb/8/8a/Banana-Fruit-Sticker.svg/240px-Banana-Fruit-Sticker.svg.png",
        embeds = {{
            title       = "BRAINROT FOUND",
            color       = 65407,
            fields = {
                {name = "Name",         value = brainrotName, inline = true},
                {name = "Money/s",      value = "$" .. valueStr,          inline = true},
                {name = "Players",      value = tostring(playerCount) .. "/8", inline = true},
                {name = "Server ID",    value = "`" .. jobId .. "`",       inline = false},
                {name = "Join Command", value = "```lua\n" .. joinCmd .. "\n```", inline = false},
            },
            footer = {text = "Banana Notifier  |  hop #" .. tostring(scoutState.hopCount) .. "  |  found: " .. tostring(scoutState.found)},
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }}
    }
    local ok, enc = pcall(function() return HttpService:JSONEncode(payload) end)
    if not ok then log("Failed to encode webhook payload"); return end
    local postOk, err = pcall(function()
        HttpService:PostAsync(WEBHOOK_URL, enc, Enum.HttpContentType.ApplicationJson)
    end)
    if postOk then
        log("Webhook sent: " .. brainrotName .. " $" .. valueStr)
    else
        log("Webhook error: " .. tostring(err))
    end
end

local serverPool   = {}
local nextCursor   = nil
local fetchingPage = false

local function fetchPage(cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100", PlaceId)
    if cursor and cursor ~= "" then url = url .. "&cursor=" .. cursor end
    local ok, res = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    if not ok or not res or not res.data then return {}, nil end
    local list = {}
    for _, sv in ipairs(res.data) do
        if sv.id and sv.id ~= game.JobId and (sv.playing or 0) >= MIN_PLAYERS then
            table.insert(list, sv)
        end
    end
    local nc = (res.nextPageCursor and res.nextPageCursor ~= "") and res.nextPageCursor or nil
    return list, nc
end

local function refillPool()
    if fetchingPage then return end
    fetchingPage = true
    task.spawn(function()
        local batch, nc = fetchPage(nextCursor)
        for i = #batch, 2, -1 do
            local j = math.random(i); batch[i], batch[j] = batch[j], batch[i]
        end
        for _, sv in ipairs(batch) do table.insert(serverPool, sv) end
        nextCursor = nc; fetchingPage = false
        if #serverPool < 50 and nc then refillPool() end
    end)
end

local function getNextServer()
    if #serverPool < 30 and not fetchingPage then refillPool() end
    if #serverPool == 0 then
        local t0 = tick()
        repeat task.wait(0.05) until #serverPool > 0 or tick()-t0 > 5
    end
    if #serverPool == 0 then return nil end
    return table.remove(serverPool, 1)
end

task.spawn(function()
    for _ = 1, 3 do
        if not fetchingPage then refillPool() end
        task.wait(0.1)
    end
end)

local function readOverhead(o)
    if not o or not o.Parent then return nil end
    if not o:IsDescendantOf(Workspace) then return nil end
    local g = o:FindFirstChild("Generation")
    if not g or not g:IsA("TextLabel") then return nil end
    local v = parseValue(g.Text)
    if v <= 0 then return nil end
    local dObj = o:FindFirstChild("DisplayName")
    local name = (dObj and dObj:IsA("TextLabel") and dObj.Text ~= "") and dObj.Text
                 or (o.Parent and o.Parent.Name) or "?"
    return v, name, g.Text
end

local function scanBest()
    local bV, bN, bR = -1, "?", ""
    for _, o in next, Workspace:GetDescendants() do
        if o.Name == "AnimalOverhead" then
            local v, n, r = readOverhead(o)
            if v and v > bV then bV = v; bN = n; bR = r end
        end
    end
    return bV, bN, bR
end

local function dismissPopups()
    pcall(function()
        for _, obj in ipairs(CoreGui:GetDescendants()) do
            if obj:IsA("TextButton") then
                local t = obj.Text:lower()
                if t == "ok" or t == "okay" or t == "leave" then
                    pcall(function() obj.MouseButton1Click:Fire() end)
                end
            end
        end
    end)
end

