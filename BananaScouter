local function sendWebhook(val, rawText, jobId, numPlayers)
    local valStr  = fmtVal(val) .. "/s"
    local joinCmd = string.format(
        "game:GetService('TeleportService'):TeleportToPlaceInstance(%d,'%s')", placeId, jobId)
    local payload = {
        username = "Banana Scout",
        embeds   = {{
            title  = "BRAINROT FOUND",
            color  = 16768000,
            fields = {
                {name="Value",        value=valStr,                         inline=true},
                {name="Players",      value=tostring(numPlayers).."/8",     inline=true},
                {name="Server ID",    value="`"..jobId.."`",                inline=false},
                {name="Raw Text",     value=rawText,                        inline=false},
                {name="Join Command", value="```lua\n"..joinCmd.."\n```",   inline=false},
            },
            footer = {text="Banana Scout  |  hops: "..St.hops.."  |  found: "..St.found},
        }}
    }
    local ok, enc = pcall(function() return HttpService:JSONEncode(payload) end)
    if not ok then log("Encode fail"); return end
    local ok2, err = pcall(function()
        HttpService:PostAsync(WEBHOOK_URL, enc, Enum.HttpContentType.ApplicationJson)
    end)
    if ok2 then log("Webhook sent: " .. valStr)
    else log("Webhook error: " .. tostring(err)) end
end

-- ============================================================
-- SERVER POOL
-- ============================================================
local serverPool   = {}
local nextCursor   = nil
local fetchingPool = false
local running      = true

local function fetchPage(cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100", placeId)
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. HttpService:UrlEncode(cursor)
    end
    local ok, res = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    if not ok or not res or not res.data then return {}, nil end
    local list = {}
    for _, sv in ipairs(res.data) do
        if sv.id and sv.id ~= game.JobId and (sv.playing or 0) >= MIN_PLAYERS then
            table.insert(list, sv)
        end
    end
    local nc = (res.nextPageCursor and res.nextPageCursor ~= "") and res.nextPageCursor or nil
    return list, nc
end

local function refillPool()
    if fetchingPool then return end
    fetchingPool = true
    task.spawn(function()
        local batch, nc = fetchPage(nextCursor)
        for i = #batch, 2, -1 do
            local j = math.random(i); batch[i], batch[j] = batch[j], batch[i]
        end
        for _, sv in ipairs(batch) do table.insert(serverPool, sv) end
        nextCursor = nc; fetchingPool = false
        if #serverPool < 50 and nc then refillPool() end
    end)
end

local function getNextServer()
    if #serverPool < 30 and not fetchingPool then refillPool() end
    if #serverPool == 0 then
        local t0 = tick()
        repeat task.wait(0.1) until not running or #serverPool > 0 or tick()-t0 > 8
    end
    if #serverPool == 0 then return nil end
    return table.remove(serverPool, 1)
end

task.spawn(function()
    for _ = 1, 3 do
        if not fetchingPool then refillPool() end; task.wait(0.1)
    end
end)

