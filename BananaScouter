log("Scout started. Min value: $" .. fmtVal(MIN_VALUE_MPS) .. "/s  PlaceId: " .. tostring(PlaceId))

local function doScoutHop(srv)
    queueSelf()
    local ok = pcall(function()
        TeleportService:TeleportToPlaceInstance(PlaceId, srv.id, LP)
    end)
    if ok then
        scoutState.hopCount = scoutState.hopCount + 1; saveScout()
        log("Hopping to server " .. srv.id .. " (hop #" .. tostring(scoutState.hopCount) .. ")")
    else
        log("Teleport failed for " .. srv.id)
    end
    task.wait(4)
end

task.spawn(function()
    while running do
        task.wait(HOP_SETTLE)
        if not running then break end

        local bestV, bestN, bestR = -1, "?", ""
        local lastSeen = tick()
        local conn

        conn = Workspace.DescendantAdded:Connect(function(obj)
            if not running then conn:Disconnect(); return end
            if obj.Name ~= "AnimalOverhead" then return end
            task.spawn(function()
                task.wait(0.05)
                if not running then return end
                local v, n, r = readOverhead(obj)
                if not v then return end
                lastSeen = tick()
                if v > bestV then bestV = v; bestN = n; bestR = r end
                SStatL.Text = "SCANNING  $" .. fmtVal(bestV) .. "/s"
                SStatL.TextColor3 = Color3.fromRGB(0, 200, 130)
            end)
        end)

        local v0, n0, r0 = scanBest()
        if v0 > bestV then bestV = v0; bestN = n0; bestR = r0 end
        if bestV > 0 then
            SStatL.Text = "SCANNING  $" .. fmtVal(bestV) .. "/s"
            SStatL.TextColor3 = Color3.fromRGB(0, 200, 130)
        else
            SStatL.Text = "SCANNING server..."
            SStatL.TextColor3 = Color3.fromRGB(60, 130, 90)
        end

        local windowStart = tick()
        while running do
            local elapsed = tick() - windowStart
            if elapsed > 0.5 and bestV <= 0 and (tick() - lastSeen) > 0.5 then break end
            if elapsed >= SCAN_WINDOW then break end
            task.wait(0.05)
        end

        conn:Disconnect()
        if not running then break end

        if bestV >= MIN_VALUE_MPS then
            local playerCount = #Players:GetPlayers()
            local jobId = game.JobId
            log("FOUND: " .. bestN .. " $" .. fmtVal(bestV) .. "/s  server: " .. jobId)
            scoutState.found = scoutState.found + 1; saveScout()
            SStatL.Text = "FOUND: " .. bestN .. " $" .. fmtVal(bestV) .. "/s"
            SStatL.TextColor3 = Color3.fromRGB(0, 255, 140)
            sendWebhook(bestN, bestV, bestR, jobId, playerCount)
            task.wait(10)
        else
            if bestV > 0 then
                log("Not good enough: " .. bestN .. " $" .. fmtVal(bestV) .. "/s  (need $" .. fmtVal(MIN_VALUE_MPS) .. "/s)")
            else
                log("No brainrots found in this server.")
            end
            SStatL.Text = bestV > 0 and ("Too low: $" .. fmtVal(bestV) .. "/s") or "Empty server"
            SStatL.TextColor3 = Color3.fromRGB(80, 100, 140)
        end

        if not running then break end

        local srv = getNextServer()
        if not srv then
            log("Pool empty, refilling...")
            nextCursor = nil; refillPool()
            local t0 = tick()
            repeat task.wait(0.1) until #serverPool > 0 or tick()-t0 > 8
            srv = getNextServer()
        end
        if srv then
            doScoutHop(srv)
        else
            log("No servers available, waiting 5s...")
            task.wait(5)
        end
    end
end)
