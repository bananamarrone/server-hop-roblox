        St.hops=St.hops+1; saveSt()
        log("Hop #"..tostring(St.hops).." -> "..srv.id)
        local t0=tick(); while running and tick()-t0<8 do task.wait(0.1) end
    else
        log("Teleport failed for "..srv.id)
    end
end

