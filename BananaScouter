log("Started. Min: " .. fmtVal(MIN_VALUE_MPS) .. "/s")

task.spawn(function()
    while running do
        STL.Text = "Waiting for server to load..."
        STL.TextColor3 = C3(60,100,140)

        -- wait for game content to load  (same as working script's wait(5))
        wait(5)
        if not running then break end

        STL.Text = "SCANNING..."
        STL.TextColor3 = C3(60,130,90)

        local bestVal, bestText = scanServer()

        if bestVal > 0 then
            STL.Text = "Found: " .. fmtVal(bestVal) .. "/s"
            STL.TextColor3 = C3(0,200,130)
            log("Best in server: " .. fmtVal(bestVal) .. "/s  raw: " .. bestText)
        else
            STL.Text = "Nothing with m/s here"
            STL.TextColor3 = C3(55,75,110)
            log("No m/s values found.")
        end

        if not running then break end

        if bestVal >= MIN_VALUE_MPS then
            St.found = St.found + 1; saveSt()
            local jobId      = game.JobId
            local numPlayers = #Players:GetPlayers()
            log("REPORTING: " .. fmtVal(bestVal) .. "/s  server: " .. jobId)
            STL.Text = "REPORTED: " .. fmtVal(bestVal) .. "/s"
            STL.TextColor3 = C3(0,255,140)
            notify("Scout Found!", fmtVal(bestVal) .. "/s sent to Discord.")
            sendWebhook(bestVal, bestText, jobId, numPlayers)
            -- wait 8s then keep going to find more
            local tw = tick()
            while running and tick()-tw < 8 do task.wait(0.1) end
        else
            if bestVal > 0 then
                log("Too low: " .. fmtVal(bestVal) .. "/s  need " .. fmtVal(MIN_VALUE_MPS))
            end
        end

        if not running then break end

        -- get next server and hop
        local srv = getNextServer()
        if not srv then
            log("Pool empty, refilling...")
            nextCursor = nil; refillPool()
            local tw = tick()
            repeat task.wait(0.1) until not running or #serverPool > 0 or tick()-tw > 8
            srv = getNextServer()
        end

        if srv then
            St.hops = St.hops + 1; saveSt()
            log("Hop #" .. tostring(St.hops) .. "  -> " .. srv.id)
            STL.Text = "Hopping... #" .. tostring(St.hops)
            STL.TextColor3 = C3(80,100,160)
            queueSelf()
            local ok = pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, srv.id, LocalPlayer)
            end)
            if ok then
                local t0 = tick()
                while running and tick()-t0 < 8 do task.wait(0.1) end
            else
                log("Teleport failed for " .. srv.id)
            end
        else
            log("No servers at all. Waiting 5s.")
            local tw = tick()
            while running and tick()-tw < 5 do task.wait(0.1) end
        end
    end
end)
