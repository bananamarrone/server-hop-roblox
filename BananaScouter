local function parseValue(raw)
    if not raw or raw=="" then return 0 end
    local n,s=raw:match("%$([%d%.]+)%s*([kKmMbBtT]?)")
    n=tonumber(n) or 0
    if s then
        s=s:lower()
        if     s=="k" then n=n*1e3
        elseif s=="m" then n=n*1e6
        elseif s=="b" then n=n*1e9
        elseif s=="t" then n=n*1e12 end
    end
    return n
end

local function fmtVal(n)
    if not n or n<=0 then return "0" end
    if     n>=1e12 then return string.format("%.2fT",n/1e12)
    elseif n>=1e9  then return string.format("%.2fB",n/1e9)
    elseif n>=1e6  then return string.format("%.2fM",n/1e6)
    elseif n>=1e3  then return string.format("%.1fK",n/1e3)
    else return tostring(math.floor(n)) end
end

-- Exact pattern from reference: AnimalOverhead -> parent.parent must be BasePart
-- Reads Generation (money/s), DisplayName, Mutation
local function findBest()
    local bestV,bestN,bestM,bestR=-1,"?","",""
    for _,o in ipairs(game:GetService("Workspace"):GetDescendants()) do
        repeat
            if o.Name~="AnimalOverhead" then break end
            local p=o.Parent and o.Parent.Parent
            if not (p and p:IsA("BasePart")) then break end
            local gen=o:FindFirstChild("Generation"); if not gen then break end
            local val=parseValue(gen.Text); if val<=0 then break end
            local dObj=o:FindFirstChild("DisplayName")
            local name=(dObj and dObj.Text~="") and dObj.Text or (o.Parent and o.Parent.Name) or "?"
            local mObj=o:FindFirstChild("Mutation")
            local mut=(mObj and mObj.Text~="") and mObj.Text or ""
            if val>bestV then bestV=val; bestN=name; bestM=mut; bestR=gen.Text end
        until true
    end
    return bestV,bestN,bestM,bestR
end

local function sendWebhook(name, val, mut, jobId, players)
    local valStr="$"..fmtVal(val).."/s"
    local mutStr=mut~="" and mut or "None"
    local joinCmd=string.format(
        "game:GetService('TeleportService'):TeleportToPlaceInstance(%d,'%s')",PlaceId,jobId)
    local payload={
        username="Banana Notifier",
        embeds={{
            title="BRAINROT FOUND",
            color=16768000,
            fields={
                {name="Name",        value=name,                   inline=true},
                {name="Money/s",     value=valStr,                 inline=true},
                {name="Mutation",    value=mutStr,                 inline=true},
                {name="Players",     value=tostring(players).."/8",inline=true},
                {name="Server ID",   value="`"..jobId.."`",        inline=false},
                {name="Join Command",value="```lua\n"..joinCmd.."\n```", inline=false},
            },
            footer={text="Banana Scout  |  hops: "..tostring(St.hops).."  |  found: "..tostring(St.found)},
            timestamp=os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }}
    }
    local ok,enc=pcall(function() return HttpService:JSONEncode(payload) end)
    if not ok then log("Encode fail"); return end
    local ok2,err=pcall(function()
        HttpService:PostAsync(WEBHOOK_URL,enc,Enum.HttpContentType.ApplicationJson)
    end)
    if ok2 then log("Webhook sent: "..name.." "..valStr)
    else log("Webhook err: "..tostring(err)) end
end

local serverPool={}
local nextCursor=nil
local fetchingPage=false

local function fetchPage(cursor)
    local url=string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100",PlaceId)
    if cursor and cursor~="" then url=url.."&cursor="..cursor end
    local ok,res=pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
    if not ok or not res or not res.data then return {},nil end
    local list={}
    for _,sv in ipairs(res.data) do
        if sv.id and sv.id~=game.JobId and (sv.playing or 0)>=MIN_PLAYERS then
            table.insert(list,sv)
        end
    end
    local nc=(res.nextPageCursor and res.nextPageCursor~="") and res.nextPageCursor or nil
    return list,nc
end

local function refillPool()
    if fetchingPage then return end
    fetchingPage=true
    task.spawn(function()
        local batch,nc=fetchPage(nextCursor)
        for i=#batch,2,-1 do local j=math.random(i); batch[i],batch[j]=batch[j],batch[i] end
        for _,sv in ipairs(batch) do table.insert(serverPool,sv) end
        nextCursor=nc; fetchingPage=false
        if #serverPool<50 and nc then refillPool() end
    end)
end

local function getNextServer()
    if #serverPool<30 and not fetchingPage then refillPool() end
    if #serverPool==0 then
        local t0=tick(); repeat task.wait(0.05) until not running or #serverPool>0 or tick()-t0>4
    end
    if #serverPool==0 then return nil end
    return table.remove(serverPool,1)
end

