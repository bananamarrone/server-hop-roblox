            KStatus.Text="Access granted!"; KStatus.TextColor3=C3(0,220,140); task.wait(0.4); unlockUI()
        else
            KSubmit.Text="CONFIRM KEY"; KStatus.Text="Wrong key."; KStatus.TextColor3=C3(210,60,60)
