-- ── VALUE PARSER ─────────────────────────────────────────────────────────────
local function parseValue(t)
    if not t then return 0 end
    local n,s = t:match("%$([%d%.]+)%s*([kKmMbBtT]?)")
    n = tonumber(n) or 0
    if s then
        s=s:lower()
        if     s=="k" then n=n*1e3
        elseif s=="m" then n=n*1e6
        elseif s=="b" then n=n*1e9
        elseif s=="t" then n=n*1e12 end
    end
    return n
end

local function fmtVal(n)
    if not n or n<=0 then return "0" end
    if     n>=1e12 then return string.format("%.2fT",n/1e12)
    elseif n>=1e9  then return string.format("%.2fB",n/1e9)
    elseif n>=1e6  then return string.format("%.2fM",n/1e6)
    elseif n>=1e3  then return string.format("%.1fK",n/1e3)
    else return tostring(math.floor(n)) end
end

local function parseInput(txt)
    if not txt or txt=="" then return 0 end
    local clean=txt:lower():gsub("%s","")
    local n,s=clean:match("^([%d%.]+)([kmbt]?)$")
    n=tonumber(n); if not n then return 0 end
    if     s=="k" then n=n*1e3
    elseif s=="m" then n=n*1e6
    elseif s=="b" then n=n*1e9
    elseif s=="t" then n=n*1e12 end
    return n
end

-- ── SCANNER ───────────────────────────────────────────────────────────────────
local function scanBest()
    local bestVal,bestName,bestRaw=-1,"?",""
    for _,o in next,workspace:GetDescendants() do
        if o.Name=="AnimalOverhead" then
            local g=o:FindFirstChild("Generation")
            if g then
                local v=parseValue(g.Text)
                if v>bestVal then
                    bestVal=v; bestRaw=g.Text
                    local d=o:FindFirstChild("DisplayName")
                    bestName=(d and d.Text~="") and d.Text or "?"
                end
            end
        end
    end
    return bestVal,bestName,bestRaw
end

