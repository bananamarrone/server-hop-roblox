local function doHop()
    if not hunting then return end
    for attempt=1,3 do
        local srv=getNextServer()
        if srv then
            S.hopCount=S.hopCount+1; S.hunting=true; saveState()
            HopBadge.Text="HOPS: "..tostring(S.hopCount)
            PoolL.Text="pool: "..tostring(#serverPool)
            queueSelf()
            local ok=pcall(function() TeleportService:TeleportToPlaceInstance(PlaceId,srv.id,LP) end)
            if ok then
                showLoading(S.hopCount)
                local t0=tick()
                while hunting and tick()-t0 < 8 do task.wait(0.1) end
                hideLoading()
                return
            end
        end
    end
    setStatus("TELEPORT FAILED",200,80,40)
end

local function startHunt()
    if S.targetValue<=0 then
        setStatus("SET A VALUE  e.g. 10m",255,70,70)
        TweenService:Create(IStroke,TI(0.1),{Color=C3(200,40,40)}):Play()
        task.delay(1.5,function() TweenService:Create(IStroke,TI(0.2),{Color=C3(24,36,58)}):Play() end)
        return
    end
    hunting=true; S.hunting=true; saveState()
    Btn.Text="STOP"; Btn.TextColor3=C3(255,220,220)
    BtnG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,C3(220,40,40)),ColorSequenceKeypoint.new(1,C3(160,20,70))})
    if MobileStopBtn then MobileStopBtn.Visible=true end
    notify("Hunt Started","Looking for $"..fmtVal(S.targetValue).."+","success")

    task.spawn(function()
        while hunting do
            local bestV,bestN,bestM,bestR=-1,"?","",""
            local lastArrival=tick()
            local found=false
            local conn

            conn=game:GetService("Workspace").DescendantAdded:Connect(function(obj)
                if not hunting then conn:Disconnect(); return end
                if obj.Name~="AnimalOverhead" then return end
                task.spawn(function()
                    task.wait(0.03)
                    if not hunting then return end
                    local p=obj.Parent and obj.Parent.Parent
                    if not (p and p:IsA("BasePart")) then return end
                    local gen=obj:FindFirstChild("Generation"); if not gen then return end
                    local val=parseValue(gen.Text); if val<=0 then return end
                    local dObj=obj:FindFirstChild("DisplayName")
                    local name=(dObj and dObj.Text~="") and dObj.Text or (obj.Parent and obj.Parent.Name) or "?"
                    local mObj=obj:FindFirstChild("Mutation")
                    local mut=(mObj and mObj.Text~="") and mObj.Text or ""
                    local blocked=false
                    for _,w in ipairs(S.blacklist) do if strContains(name,w) then blocked=true; break end end
                    if blocked then return end
                    lastArrival=tick()
                    if val>bestV then bestV=val; bestN=name; bestM=mut; bestR=gen.Text end
                    setStatus("SCANNING  $"..fmtVal(bestV).."/s",0,200,130)
                    BestL.Text="best: "..bestN.."  "..bestR; BestL.TextColor3=C3(55,85,125)
                    MutL.Text=mut~="" and ("mutation: "..mut) or ""
                    setBar(0.7)
                    if val>=S.targetValue and passesWhitelist(bestN,S.whitelist) and not S.hopAnyway then
                        conn:Disconnect(); found=true
                    end
                end)
            end)

            setStatus("SCANNING...",0,170,110); setBar(0.2)
            local v0,n0,m0,r0=findBest(S.blacklist)
            if v0>bestV then bestV=v0; bestN=n0; bestM=m0; bestR=r0 end
            if bestV>0 then
                setStatus("SCANNING  $"..fmtVal(bestV).."/s",0,200,130)
                BestL.Text="best: "..bestN.."  "..bestR; BestL.TextColor3=C3(55,85,125)
                MutL.Text=bestM~="" and ("mutation: "..bestM) or ""
                setBar(0.5)
                if bestV>=S.targetValue and passesWhitelist(bestN,S.whitelist) and not S.hopAnyway then found=true end
            end

            if not found then
                local t0=tick()
                while hunting and not found do
                    local el=tick()-t0
                    setBar(0.5+math.min(el/SCAN_WINDOW,1)*0.5)
                    if bestV>0 then setStatus("SCANNING  $"..fmtVal(bestV).."/s",0,200,130)
                    else setStatus("SCANNING... "..tostring(math.max(0,math.ceil(SCAN_WINDOW-el))).."s",60,130,90) end
                    if el>0.4 and bestV<=0 and tick()-lastArrival>0.4 then break end
                    if el>=SCAN_WINDOW then break end
                    task.wait(0.05)
                end
            end

            conn:Disconnect()
            if not hunting then break end

            if found or (bestV>=S.targetValue and passesWhitelist(bestN,S.whitelist) and not S.hopAnyway) then
                setStatus("FOUND!  "..bestN.."  "..bestR,0,255,160)
                BestL.Text="LOCKED:  "..bestN.."  "..bestR; BestL.TextColor3=C3(0,220,140)
                MutL.Text=bestM~="" and ("mutation: "..bestM) or ""
                setBar(1); playAlert()
                notify("FOUND IT!",bestN.." -- "..bestR,"success")
                for _=1,6 do
                    TweenService:Create(CardBorder,TI(0.1),{Color=C3(0,255,150)}):Play(); task.wait(0.13)
                    TweenService:Create(CardBorder,TI(0.1),{Color=C3(22,34,55)}):Play(); task.wait(0.13)
                end
                stopHunt(false); break
            end

            if bestV>0 then setStatus("$"..fmtVal(bestV).."/s -- hopping",60,100,160) else setStatus("nothing -- hopping",55,75,110) end
            doHop()
        end
    end)
end

