local function validateKey(k)
    if not k or k=="" then return end
    KSubmit.Text="CHECKING..."; KStatus.Text="Checking..."; KStatus.TextColor3=C3(80,120,180)
    task.spawn(function()
        local tk=fetchTodayKey()
        if not tk then
            KSubmit.Text="CONFIRM KEY"; KStatus.Text="Cannot reach key server."
            KStatus.TextColor3=C3(200,100,40)
            TweenService:Create(KIStroke,TI(0.1),{Color=C3(180,80,30)}):Play()
            task.delay(1.5,function() KIStroke.Color=C3(24,36,58) end); return
        end
        if k:lower()==tk:lower() then
            KStatus.Text="Access granted!"; KStatus.TextColor3=C3(0,220,140)
            task.wait(0.4); unlockUI()
        else
            KSubmit.Text="CONFIRM KEY"; KStatus.Text="Wrong key."
            KStatus.TextColor3=C3(210,60,60)
            TweenService:Create(KIStroke,TI(0.1),{Color=C3(200,40,40)}):Play()
            task.delay(1.5,function() KIStroke.Color=C3(24,36,58) end)
        end
    end)
end
