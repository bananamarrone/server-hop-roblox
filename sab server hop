local function doHop()
    local srv = getNextServer(true)
    if not srv then
        setStatus("NO SERVERS FOUND", 180, 80, 40)
        log("No server available.")
        return false
    end
    hopCount = hopCount + 1
    HopBadge.Text = "HOPS: " .. tostring(hopCount)
    PoolL.Text = "pool: " .. tostring(#serverPool)
    queueSelf()
    local ok = pcall(function()
        TeleportService:TeleportToPlaceInstance(PlaceId, srv.id, LP)
    end)
    if ok then
        showLoading(hopCount)
        log("Hop #" .. tostring(hopCount) .. " -> " .. srv.id)
        local t0 = tick()
        while hunting and tick()-t0 < 8 do task.wait(0.1) end
        hideLoading()
    else
        log("Teleport failed " .. srv.id)
    end
    return true
end

local function startHunt()
    targetValue = parseInput(ValBox.Text)
    if targetValue <= 0 then
        setStatus("SET A VALUE  e.g. 30m", 255, 70, 70)
        TweenService:Create(ValStroke, TweenInfo.new(0.1), {Color=C3(200,40,40)}):Play()
        task.delay(1.5, function()
            TweenService:Create(ValStroke, TweenInfo.new(0.2), {Color=C3(24,36,58)}):Play()
        end)
        return
    end

    hunting = true
    Btn.Text = "HUNTING..."
    Btn.TextColor3 = C3(180,240,200)
    BtnG.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, C3(0,100,70)),
        ColorSequenceKeypoint.new(1, C3(0,80,100))
    })
    StopBtn.Visible = true
    log("Hunt started. Target: $" .. fmtVal(targetValue) .. "/s")

    task.spawn(function()
        while hunting do
            setStatus("SCANNING...", 0, 170, 110)
            BestL.Text = "best: --"; BestL.TextColor3 = C3(38,55,82)
            MutL.Text = ""

            local bestV, bestN, bestM, bestR = -1, "?", "", ""
            local lastArrival = tick()
            local conn

            conn = game:GetService("Workspace").DescendantAdded:Connect(function(obj)
                if not hunting then conn:Disconnect(); return end
                if obj.Name ~= "AnimalOverhead" then return end
                task.spawn(function()
                    task.wait(0.03)
                    if not hunting then return end
                    local p = obj.Parent and obj.Parent.Parent
                    if not (p and p:IsA("BasePart")) then return end
                    local gen = obj:FindFirstChild("Generation")
                    if not gen then return end
                    local val = num(gen.Text)
                    if val <= 0 then return end
                    local dObj = obj:FindFirstChild("DisplayName")
                    local name = (dObj and dObj.Text ~= "") and dObj.Text or (obj.Parent and obj.Parent.Name) or "?"
                    local mObj = obj:FindFirstChild("Mutation")
                    local mut = (mObj and mObj.Text ~= "") and mObj.Text or ""
                    lastArrival = tick()
                    if val > bestV then bestV = val; bestN = name; bestM = mut; bestR = gen.Text end
                    setStatus("SCANNING  $" .. fmtVal(bestV) .. "/s", 0, 200, 130)
                    BestL.Text = "best: " .. bestN .. "  " .. bestR
                    MutL.Text = mut ~= "" and ("mutation: " .. mut) or ""
                end)
            end)

            local v0, n0, m0, r0 = findBest()
            if v0 > bestV then bestV = v0; bestN = n0; bestM = m0; bestR = r0 end
            if bestV > 0 then
                setStatus("SCANNING  $" .. fmtVal(bestV) .. "/s", 0, 200, 130)
                BestL.Text = "best: " .. bestN .. "  " .. bestR
                MutL.Text = bestM ~= "" and ("mutation: " .. bestM) or ""
            end

            local t0 = tick()
            while hunting do
                local el = tick() - t0
                if el > 0.5 and bestV <= 0 and tick()-lastArrival > 0.5 then break end
                if el >= SCAN_WINDOW then break end
                task.wait(0.05)
            end
            conn:Disconnect()
            if not hunting then break end

            if bestV >= targetValue then
                foundCount = foundCount + 1
                setStatus("FOUND!  " .. bestN .. "  " .. bestR, 0, 255, 160)
                BestL.Text = "LOCKED: " .. bestN .. "  " .. bestR
                BestL.TextColor3 = C3(0,220,140)
                MutL.Text = bestM ~= "" and ("mutation: " .. bestM) or ""
                log("FOUND: " .. bestN .. " " .. bestR)
                local sound = Instance.new("Sound", game:GetService("SoundService"))
                sound.SoundId = "rbxassetid://4590662766"; sound.Volume = 1
                pcall(function() sound:Play() end)
                task.delay(5, function() pcall(function() sound:Destroy() end) end)
                stopHunt()
                break
            end

            if bestV > 0 then
                setStatus("$" .. fmtVal(bestV) .. "/s too low -- hopping", 60, 100, 160)
            else
                setStatus("nothing -- hopping", 55, 75, 110)
            end

            doHop()
        end
    end)
end

