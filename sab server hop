-- HUNT LOGIC
local function setStatus(txt,r,g,b)
    StatL.Text=txt; StatL.TextColor3=C3(r,g,b)
end
local function isWanted(name)
    local nl=name:lower()
    if next(whitelistSet)~=nil then return whitelistSet[nl]==true end
    if blacklistSet[nl] then return false end
    return true
end
local function stopHunt()
    hunting=false
    Settings.wasHunting=false; saveSettings()
    StartBtn.Text="START HUNTING"; StartBtn.TextColor3=C3(0,8,6)
    BtnG.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,C3(0,230,160)),ColorSequenceKeypoint.new(1,C3(0,190,255))})
    setStatus("STOPPED",70,70,95); setBar(0)
    LiveDot.BackgroundColor3=C3(35,48,68)
end
local function startHunt()
    if targetValue<=0 then
        setStatus("SET A TARGET FIRST!",255,70,70)
        TweenService:Create(IStroke,TI(0.1),{Color=C3(200,40,40)}):Play()
        task.delay(1.2,function() IStroke.Color=C3(0,150,90) end); return
    end
    hunting=true
    Settings.wasHunting=true; saveSettings()
    StartBtn.Text="STOP"; StartBtn.TextColor3=C3(255,200,200)
    BtnG.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,C3(220,40,40)),ColorSequenceKeypoint.new(1,C3(160,20,70))})
    log("Hunt started. Target: $"..fmtVal(targetValue))
    task.spawn(function()
        while hunting do
            -- wait up to 8s for at least one AnimalOverhead to exist (game may not have loaded yet)
            local t0=tick()
            while hunting and tick()-t0<8 do
                local found=false
                for _,o in next,workspace:GetDescendants() do
                    if o.Name=="AnimalOverhead" then found=true; break end
                end
                if found then break end
                setStatus("Waiting for game to load... ("..string.format("%.0f",8-(tick()-t0)).."s)",60,90,140)
                setBar((tick()-t0)/8)
                task.wait(0.2)
            end
            if not hunting then break end

            -- scan in a rolling window: keep scanning every 0.15s, stop when bestVal
            -- hasn't improved for 1.5s (game has settled) or 6s total have passed
            local bestVal,bestName,bestRaw=-1,"?",""
            local lastImprove=tick()
            local scanStart=tick()
            while hunting and tick()-scanStart<6 do
                local v,n,r=scanBest()
                if v>bestVal then bestVal=v; bestName=n; bestRaw=r; lastImprove=tick() end
                local elapsed=tick()-scanStart
                setBar(math.clamp(elapsed/6,0,1))
                if bestVal>0 then
                    setStatus("SCANNING  $"..fmtVal(bestVal),0,170,110)
                    BestL.Text="best: "..bestName.."  "..bestRaw
                    BestL.TextColor3=C3(55,85,125)
                else
                    setStatus("SCANNING...",0,120,80)
                end
                -- if value hasn't changed in 1.5s and we've been scanning at least 1s, settle early
                if bestVal>0 and tick()-lastImprove>1.5 and elapsed>1 then break end
                task.wait(0.15)
            end
            if not hunting then break end
            if bestVal>=targetValue and isWanted(bestName) then
                setStatus("FOUND!  "..bestName.."  "..bestRaw,0,255,160)
                BestL.Text="STAY!  "..bestName.."  "..bestRaw; BestL.TextColor3=C3(0,220,140)
                setBar(1); playAlert()
                for _=1,5 do
                    TweenService:Create(CardBorder,TI(0.12),{Color=C3(0,255,150)}):Play()
                    task.wait(0.15)
                    TweenService:Create(CardBorder,TI(0.12),{Color=C3(22,34,55)}):Play()
                    task.wait(0.15)
                end
                stopHunt(); break
            elseif bestVal>=targetValue and not isWanted(bestName) then
                setStatus("SKIP (blacklisted): "..bestName,120,80,40)
                log("Skipping: "..bestName)
            end
            hopCount=hopCount+1; HopB.Text="HOPS: "..hopCount
            FootL.Text="last: "..bestName.."  "..bestRaw
            setStatus("HOP #"..hopCount,70,120,200); setBar(0)
            doHop()
        end
    end)
end
