-- ============================================================
-- VALUE PARSER  (exact copy from working script)
-- ============================================================
local function parseNumber(text)
    text = text:gsub(",", ""):upper()
    local num, suffix = text:match("([%d%.]+)%s*([KMB]?)")
    num = tonumber(num)
    if not num then return nil end
    if suffix == "K" then num = num * 1e3
    elseif suffix == "M" then num = num * 1e6
    elseif suffix == "B" then num = num * 1e9 end
    return num
end

local function fmtVal(n)
    if not n or n <= 0 then return "0" end
    if n >= 1e9 then return string.format("%.2fB", n/1e9)
    elseif n >= 1e6 then return string.format("%.2fM", n/1e6)
    elseif n >= 1e3 then return string.format("%.1fK", n/1e3)
    else return tostring(math.floor(n)) end
end

-- ============================================================
-- SERVER SCANNER  (exact logic from working script)
-- ============================================================
local function scanServer(minValue)
    local bestVal  = 0
    local bestText = ""
    for _, obj in ipairs(workspace:GetDescendants()) do
        pcall(function()
            local txt = nil
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                txt = obj.Text
            elseif obj:IsA("StringValue") or obj:IsA("NumberValue") or obj:IsA("IntValue") then
                txt = tostring(obj.Value)
            end
            if not txt or txt == "" then return end
            if txt:lower():find("m/s") then
                local val = parseNumber(txt)
                if val and val > bestVal then
                    bestVal  = val
                    bestText = txt
                end
            end
        end)
    end
    return bestVal, bestText
end

local function hasGoodBrainrot(minValue)
    local val, _ = scanServer(minValue)
    return val >= minValue, val
end

