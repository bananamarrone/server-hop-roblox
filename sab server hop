    PoolL.Text = "server pool: " .. tostring(#serverPool)
    queueSelf()
    log("Hop #" .. tostring(hopCount) .. "  -> " .. srv.id)
    showLoading(hopCount)
    local ok = pcall(function()
        TeleportService:TeleportToPlaceInstance(placeId, srv.id, LocalPlayer)
    end)
    if ok then
        local t0 = tick()
        while hunting and tick()-t0 < 8 do task.wait(0.1) end
    else
        log("Teleport failed, trying next")
    end
    hideLoading()
end

local function startHunt()
    local v = parseNumber(ValBox.Text)
    if not v or v <= 0 then
        setStatus("SET A VALUE  e.g. 30M", 255,70,70)
        TweenService:Create(ValStroke,TI(0.1),{Color=C3(200,40,40)}):Play()
        task.delay(1.5, function()
            TweenService:Create(ValStroke,TI(0.2),{Color=C3(0,150,90)}):Play()
        end)
        return
    end
    targetValue = v
    hunting = true
    Btn.Text = "HUNTING..."; Btn.TextColor3 = C3(180,240,200)
    BtnG.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, C3(0,100,70)),
        ColorSequenceKeypoint.new(1, C3(0,80,100))
    })
    StopBtn.Visible = true
    log("Hunt started. Target: " .. fmtVal(targetValue) .. "/s")

    task.spawn(function()
        while hunting do
            setStatus("SCANNING...", 0,170,110)
            BestL.Text = "scanning..."
            BestL.TextColor3 = C3(38,55,82)

            -- wait for server to load content
            wait(3)
            if not hunting then break end

            local bestVal, bestText = scanServer(targetValue)

            if bestVal > 0 then
                BestL.Text = "best: " .. fmtVal(bestVal) .. "/s  (\"" .. bestText .. "\")"
                BestL.TextColor3 = C3(55,85,125)
                setStatus("SCANNED: " .. fmtVal(bestVal) .. "/s", 0,200,130)
                log("Scanned best: " .. fmtVal(bestVal) .. "/s  raw=\"" .. bestText .. "\"")
            else
                BestL.Text = "nothing with /s found"
                BestL.TextColor3 = C3(38,55,82)
                setStatus("nothing found -- hopping", 55,75,110)
                log("No m/s values found here.")
            end

            if not hunting then break end

            if bestVal >= targetValue then
                setStatus("FOUND!   " .. fmtVal(bestVal) .. "/s", 0,255,160)
                BestL.Text = "STAY HERE!  " .. fmtVal(bestVal) .. "/s"
                BestL.TextColor3 = C3(0,220,140)
                TweenService:Create(CardStroke,TI(0.15),{Color=C3(0,255,140)}):Play()
                notify("BANANA FOUND!", fmtVal(bestVal) .. "/s brainrot in this server!")
                warn("[BSH] FOUND: " .. fmtVal(bestVal) .. "/s -- raw: " .. bestText)
                local snd = Instance.new("Sound", game:GetService("SoundService"))
                snd.SoundId = "rbxassetid://4590662766"; snd.Volume = 1
                pcall(function() snd:Play() end)
                task.delay(5, function() pcall(function() snd:Destroy() end) end)
                stopHunt()
                break
            end

            setStatus(fmtVal(bestVal) .. "/s too low -- hopping", 60,100,160)
            doHop()
        end
    end)
end

Btn.MouseButton1Click:Connect(function()
    if not hunting then startHunt() end
end)
StopBtn.MouseButton1Click:Connect(function()
    if hunting then stopHunt() end
end)

