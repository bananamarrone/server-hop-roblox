-- ██  HUNT LOGIC
-- ────────────────────────────────────────────────────────────────────────────
local hunting = false
local function setStatus(txt,r,g,b) StatL.Text=txt; StatL.TextColor3=C3(r,g,b) end

local function stopHunt(emergency)
    hunting=false; S.hunting=false; saveState()
    Btn.Text="START HUNTING"; Btn.TextColor3=C3(0,8,6)
    BtnG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,C3(0,230,160)),ColorSequenceKeypoint.new(1,C3(0,190,255))})
    if MobileStopBtn then MobileStopBtn.Visible=false end
    hideLoading()
    if emergency then
        setStatus("⛔ EMERGENCY STOP",220,60,60); notify("Emergency Stop","Hopping stopped immediately.","error")
        for _=1,4 do
            TweenService:Create(CardBorder,TI(0.1),{Color=C3(220,50,50)}):Play(); task.wait(0.12)
            TweenService:Create(CardBorder,TI(0.1),{Color=C3(22,34,55)}):Play(); task.wait(0.12)
        end
    else setStatus("STOPPED",70,70,95) end
    setBar(0); LiveDot.BackgroundColor3=C3(35,48,68)
end

-- ─────────────────────────────────────────────────────────────────────────────
-- SCAN STRATEGY:
-- We use DescendantAdded on Workspace to react the INSTANT an AnimalOverhead
-- appears. No polling, no fake timers.
-- After joining a server:
--   1. Hook DescendantAdded
--   2. Run one immediate full scan (catches anything already loaded)
--   3. Wait up to SCAN_WINDOW seconds for new overheads to stream in
--   4. After SCAN_WINDOW with no new overheads, make the hop/stop decision
-- This means: if a brainrot is there, we catch it within ~0.1s of it loading.
-- ─────────────────────────────────────────────────────────────────────────────
local SCAN_WINDOW  = 2.0   -- seconds to wait for pets to stream in after joining
local HOP_SETTLE   = 0.3   -- tiny settle after teleport fires before we start watching

local lastHop = 0
local function doHop()
    if not hunting then return end
    local srv = getNextServer()
    if not srv then
        notify("No Servers","Refilling pool...","warn")
        nextCursor=nil; refillPool()
        local t0=tick(); repeat task.wait(0.05) until #serverPool>0 or tick()-t0>6
        srv = getNextServer()
    end
    if not srv then setStatus("NO SERVERS — retry in 3s",200,80,40); task.wait(3); return end

    showLoading(); queueSelf()
    local ok = pcall(function()
        TeleportService:TeleportToPlaceInstance(PlaceId, srv.id, LP)
    end)
    if ok then
        S.hopCount+=1; S.hunting=true; saveState(); lastHop=tick()
        HopBadge.Text="HOPS: "..S.hopCount
        PoolL.Text=("pool: %d"):format(#serverPool)
    else
        hideLoading(); setStatus("TELEPORT FAILED — retrying",180,80,40)
        task.wait(1)
    end
    -- Script ends here on this server; queue_on_teleport re-runs it in the new one
    task.wait(3); hideLoading()
end

local function checkAndDecide(bestV, bestN, bestR)
    -- Called whenever we have a scan result to evaluate
    if not hunting then return end
    if bestV > 0 then
        BestL.Text = ("best: %s  %s"):format(bestN, bestR)
        BestL.TextColor3 = C3(55, 85, 125)
    end
    if bestV >= S.targetValue and passesWhitelist(bestN) and not S.hopAnyway then
        -- FOUND!
        setStatus(("✦ FOUND  %s  %s"):format(bestN,bestR), 0, 255, 160)
        BestL.Text=("LOCKED ·  %s  %s"):format(bestN,bestR); BestL.TextColor3=C3(0,220,140)
        setBar(1); playAlert()
        notify("🍌 FOUND IT!", bestN.." — "..bestR, "success")
        for _=1,6 do
            TweenService:Create(CardBorder,TI(0.1),{Color=C3(0,255,150)}):Play(); task.wait(0.13)
            TweenService:Create(CardBorder,TI(0.1),{Color=C3(22,34,55)}):Play(); task.wait(0.13)
        end
        stopHunt(false)
        return true  -- signal: stop hopping
    end
    return false
end

local function startHunt()
    if S.targetValue <= 0 then
        setStatus("SET A VALUE  e.g. 10m",255,70,70)
        TweenService:Create(IStroke,TI(0.1),{Color=C3(200,40,40)}):Play()
        task.delay(1.5,function() TweenService:Create(IStroke,TI(0.2),{Color=C3(24,36,58)}):Play() end)
        return
    end
    hunting=true; S.hunting=true; saveState()
    Btn.Text="STOP"; Btn.TextColor3=C3(255,220,220)
    BtnG.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,C3(220,40,40)),ColorSequenceKeypoint.new(1,C3(160,20,70))})
    if MobileStopBtn then MobileStopBtn.Visible=true end
    notify("Hunt Started","Looking for $"..fmtVal(S.targetValue).."+","success")

    task.spawn(function()
        while hunting do
            -- ── Phase 1: tiny settle so we're actually in the server ──
            task.wait(HOP_SETTLE)
            if not hunting then break end

            -- ── Phase 2: hook DescendantAdded to catch overheads as they stream ──
            local bestV, bestN, bestR = -1, "?", ""
            local lastSeen = tick()   -- timestamp of last overhead arriving
            local found = false
            local conn

            conn = Workspace.DescendantAdded:Connect(function(obj)
                if not hunting then conn:Disconnect(); return end
                if obj.Name ~= "AnimalOverhead" then return end
                -- Small wait for children (Generation label) to be added
                task.defer(function()
                    if not hunting then return end
                    local v, n, r = readOverhead(obj)
                    if not v then return end
                    lastSeen = tick()
                    if v > bestV then bestV=v; bestN=n; bestR=r end
                    setStatus(("SCANNING · $%s"):format(fmtVal(bestV)), 0, 200, 130)
                    BestL.Text=("best: %s  %s"):format(bestN,bestR); BestL.TextColor3=C3(55,85,125)
                    setBar(0.6)
                    -- If this already meets target, fire immediately — don't wait for window
                    if bestV >= S.targetValue and passesWhitelist(bestN) and not S.hopAnyway then
                        conn:Disconnect()
                        found = true
                    end
                end)
            end)

            -- ── Phase 3: also do an immediate full scan of what's already loaded ──
            setStatus("SCANNING...", 0, 170, 110); setBar(0.2)
            local v0, n0, r0 = scanBest()
            if v0 > bestV then bestV=v0; bestN=n0; bestR=r0 end
            if bestV > 0 then
                setStatus(("SCANNING · $%s"):format(fmtVal(bestV)), 0, 200, 130)
                BestL.Text=("best: %s  %s"):format(bestN,bestR); BestL.TextColor3=C3(55,85,125)
                setBar(0.5)
                if bestV >= S.targetValue and passesWhitelist(bestN) and not S.hopAnyway then
                    found = true
                end
            end

            -- ── Phase 4: wait for SCAN_WINDOW for more overheads to stream in ──
            -- We stop waiting early if found=true OR if no new overheads for 0.5s
            -- after the window started (avoids wasting time in empty servers)
            local windowStart = tick()
            local hadAny = bestV > 0

            while hunting and not found do
                local elapsed = tick() - windowStart
                local prog = math.min(elapsed / SCAN_WINDOW, 1)
                setBar(0.5 + prog * 0.5)

                -- If we found something in the scan, show it
                if bestV > 0 then
                    setStatus(("SCANNING · $%s"):format(fmtVal(bestV)), 0, 200, 130)
                else
                    setStatus(("SCANNING... %ds"):format(math.ceil(SCAN_WINDOW-elapsed)), 60, 130, 90)
                end

                -- Stop window early: been 0.5s since last overhead AND had no pets at all
                -- (means this is an empty/fast server, move on quickly)
                if elapsed > 0.5 and not hadAny and (tick()-lastSeen) > 0.5 then
                    break
                end

                -- Full window elapsed
                if elapsed >= SCAN_WINDOW then break end

                task.wait(0.05)
            end

            conn:Disconnect()
            if not hunting then break end

            -- ── Phase 5: decide ──
            if found or checkAndDecide(bestV, bestN, bestR) then
                -- checkAndDecide handles the stop, just break the loop
                if found then checkAndDecide(bestV, bestN, bestR) end
                break
            end

            -- Nothing good — hop
            if bestV > 0 then
                setStatus(("$%s here — hopping"):format(fmtVal(bestV)), 60, 100, 160)
            else
                setStatus("no brainrots — hopping", 55, 75, 110)
            end
            doHop()
        end
    end)
end

