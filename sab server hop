-- FIX: parseValue now handles raw numbers like "10000000" AND "$10m" format
local function parseValue(raw)
    if not raw or raw=="" then return 0 end
    -- Strip leading $ and whitespace
    local t = raw:gsub("^%s*%$?%s*",""):lower():gsub("%s+","")
    if t=="" then return 0 end
    -- Try suffix format: 10m, 1.5b, etc.
    local n, s = t:match("^([%d%.]+)([kmbt]?)$")
    n = tonumber(n)
    if not n then return 0 end
    if     s=="k" then n=n*1e3
    elseif s=="m" then n=n*1e6
    elseif s=="b" then n=n*1e9
    elseif s=="t" then n=n*1e12 end
    return n
end

local function fmtVal(n)
    if not n or n<=0 then return "0" end
    if n>=1e12 then return ("%.2fT"):format(n/1e12)
    elseif n>=1e9  then return ("%.2fB"):format(n/1e9)
    elseif n>=1e6  then return ("%.2fM"):format(n/1e6)
    elseif n>=1e3  then return ("%.1fK"):format(n/1e3)
    else return tostring(math.floor(n)) end
end

-- Convert display text back to input-box friendly string
local function valToInput(n)
    if not n or n<=0 then return "" end
    if n>=1e12 then return ("%.2fT"):format(n/1e12):gsub("%.00","")
    elseif n>=1e9  then return ("%.2fB"):format(n/1e9):gsub("%.00","")
    elseif n>=1e6  then return ("%.2fM"):format(n/1e6):gsub("%.00","")
    elseif n>=1e3  then return ("%.1fK"):format(n/1e3):gsub("%.0","")
    else return tostring(math.floor(n)) end
end

local function strContains(a,b)
    if not a or not b or b=="" then return false end
    return a:lower():find(b:lower(),1,true) ~= nil
end

