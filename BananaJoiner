local function fetchDiscordMessages()
    local url = "https://discord.com/api/v10/channels/" .. DISCORD_CHANNEL_ID .. "/messages?limit=10"
    local headers = {Authorization = "Bot " .. DISCORD_BOT_TOKEN}
    local ok, res = pcall(function()
        return HttpService:GetAsync(url, false, headers)
    end)
    if not ok or not res then
        log("Failed to fetch Discord messages: " .. tostring(res))
        return {}
    end
    local decOk, msgs = pcall(function() return HttpService:JSONDecode(res) end)
    if not decOk or type(msgs) ~= "table" then
        log("Failed to decode Discord response")
        return {}
    end
    return msgs
end

local function extractJobId(text)
    local jobId = text:match("([0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+)")
    return jobId
end

local function extractBrainrotName(embedFields)
    if not embedFields then return "Unknown" end
    for _, field in ipairs(embedFields) do
        if field.name == "Name" then return field.value end
    end
    return "Unknown"
end

local function extractValueStr(embedFields)
    if not embedFields then return "?" end
    for _, field in ipairs(embedFields) do
        if field.name == "Money/s" then return field.value end
    end
    return "?"
end

local function parseNewAlerts(msgs)
    local alerts = {}
    for _, msg in ipairs(msgs) do
        if seenMessageIds[msg.id] then break end
        seenMessageIds[msg.id] = true
        if msg.embeds and #msg.embeds > 0 then
            for _, embed in ipairs(msg.embeds) do
                if embed.title == "BRAINROT FOUND" and embed.fields then
                    local jobId = nil
                    for _, field in ipairs(embed.fields) do
                        if field.name == "Server ID" then
                            jobId = field.value:match("([0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+)")
                        end
                    end
                    if jobId then
                        table.insert(alerts, {
                            jobId     = jobId,
                            name      = extractBrainrotName(embed.fields),
                            valueStr  = extractValueStr(embed.fields),
                            msgId     = msg.id,
                        })
                        log("New alert: " .. extractBrainrotName(embed.fields) .. " " .. extractValueStr(embed.fields) .. " ID: " .. jobId)
                    end
                end
            end
        end
    end
    return alerts
end

