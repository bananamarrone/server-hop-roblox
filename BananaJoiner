-- ── JOIN LOGIC ────────────────────────────────────────────────────────────────
local function doJoin(jobId, n)
    if isJoining then
        table.insert(joinQueue, {jobId=jobId, n=n}); return
    end
    isJoining=true
    task.spawn(function()
        for i=1,n do
            if not running then break end
            dismissPopups()
            totalJoins=totalJoins+1
            ProgLbl.Text="joining "..tostring(i).."/"..tostring(n).."  total: "..tostring(totalJoins)
            TweenService:Create(PBar,TI(0.1),{Size=U2(i/n,0,1,0)}):Play()
            pcall(function() TeleportService:TeleportToPlaceInstance(PlaceId,jobId,LP) end)
            if i<n then task.wait(JOIN_COOLDOWN) end
        end
        isJoining=false
        PBar.Size=U2(0,0,1,0)
        ProgLbl.Text="total joins: "..tostring(totalJoins).."  queue: "..tostring(#joinQueue)
        if #joinQueue>0 then
            local nxt=table.remove(joinQueue,1); doJoin(nxt.jobId,nxt.n)
        else
            SL.Text="Done joining. Watching..."; SL.TextColor3=C3(80,100,140)
        end
    end)
end

