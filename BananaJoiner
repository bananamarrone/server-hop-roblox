-- ── DISCORD FETCH ─────────────────────────────────────────────────────────────
local function fetchMsgs()
    local url="https://discord.com/api/v10/channels/"..DISCORD_CHANNEL_ID.."/messages?limit=10"
    local headers={Authorization="Bot "..DISCORD_BOT_TOKEN}
    local ok,res=pcall(function() return HttpService:GetAsync(url,false,headers) end)
    if not ok or not res then return {} end
    local dok,msgs=pcall(function() return HttpService:JSONDecode(res) end)
    if not dok or type(msgs)~="table" then return {} end
    return msgs
end

local function extractJobId(txt)
    return txt:match("([0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+)")
end

local function parseAlerts(msgs)
    local alerts={}
    for _,msg in ipairs(msgs) do
        if seenIds[msg.id] then break end
        seenIds[msg.id]=true
        if msg.embeds and #msg.embeds>0 then
            for _,emb in ipairs(msg.embeds) do
                if emb.title=="BRAINROT FOUND" and emb.fields then
                    local name,valStr,mut,jobId,players="?","?","",nil,0
                    for _,f in ipairs(emb.fields) do
                        if f.name=="Name"      then name=f.value end
                        if f.name=="Money/s"   then valStr=f.value:gsub("^%$",""):gsub("/s$","") end
                        if f.name=="Mutation"  then if f.value~="None" then mut=f.value end end
                        if f.name=="Server ID" then jobId=extractJobId(f.value) end
                        if f.name=="Players"   then players=tonumber(f.value:match("^(%d+)")) or 0 end
                    end
                    if jobId then
                        table.insert(alerts,{name=name,valStr=valStr,mut=mut,jobId=jobId,players=players})
                    end
                end
            end
        end
    end
    return alerts
end

