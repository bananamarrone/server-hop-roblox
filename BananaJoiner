local function spamJoin(jobId, brainrotName, valueStr, count)
    if isJoining then
        addLog("Already joining, queuing: " .. brainrotName)
        table.insert(joinQueue, {jobId=jobId, name=brainrotName, valueStr=valueStr, count=count})
        return
    end
    isJoining = true
    StatusLbl.Text = "JOINING: " .. brainrotName
    StatusLbl.TextColor3 = C3(255,200,60)
    AlertLbl.Text = brainrotName .. "\n" .. valueStr
    AlertLbl.TextColor3 = C3(0,220,140)
    addLog("Starting spam join: " .. brainrotName .. " x" .. tostring(count))

    task.spawn(function()
        for i = 1, count do
            if not running then break end
            dismissPopups()
            local ok = pcall(function()
                TeleportService:TeleportToPlaceInstance(PlaceId, jobId, LP)
            end)
            if ok then
                totalJoins = totalJoins + 1
                ProgressLbl.Text = "join " .. tostring(i) .. "/" .. tostring(count) .. "  total: " .. tostring(totalJoins)
                TweenService:Create(ProgressBar, TI(0.1), {Size = U2(i/count, 0, 1, 0)}):Play()
                addLog("Join " .. tostring(i) .. "/" .. tostring(count) .. " -> " .. jobId:sub(1,8) .. "...")
            else
                addLog("Join " .. tostring(i) .. " FAILED")
            end
            task.wait(JOIN_COOLDOWN)
        end
        addLog("Done: " .. brainrotName .. " (" .. tostring(count) .. " joins)")
        isJoining = false
        ProgressBar.Size = U2(0,0,1,0)
        if #joinQueue > 0 then
            local next = table.remove(joinQueue, 1)
            spamJoin(next.jobId, next.name, next.valueStr, next.count)
        else
            StatusLbl.Text = "Waiting for alerts..."
            StatusLbl.TextColor3 = C3(80,100,140)
        end
    end)
end

task.spawn(function()
