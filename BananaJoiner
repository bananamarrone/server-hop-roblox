-- MAIN POLL LOOP
task.spawn(function()
    local first=fetchMsgs()
    for _,m in ipairs(first) do seenIds[m.id]=true end
    print("[JOINER] Synced "..tostring(#first).." existing messages. Watching for new alerts.")
    SL.Text="Watching for alerts..."; SL.TextColor3=C3(80,100,140)

    while running do
        task.wait(FETCH_INTERVAL)
        if not running then break end

        local msgs=fetchMsgs()
        local alerts=parseAlerts(msgs)

        for _,alert in ipairs(alerts) do
            local timeStr=os.date("%H:%M:%S")
            local entry={
                name=alert.name, valStr=alert.valStr, mut=alert.mut,
                jobId=alert.jobId, players=alert.players, timeStr=timeStr
            }
            table.insert(logEntries,entry)
            addLogRow(entry)

            local cnt=getSpamCount(SpInput)
            SL.Text="NEW ALERT: "..alert.name.."  $"..alert.valStr.."/s"; SL.TextColor3=C3(0,230,150)
            AL.Text=alert.name.."  $"..alert.valStr.."/s"
            if alert.mut~="" then AL.Text=AL.Text.."  |  "..alert.mut end
            AL.TextColor3=C3(0,220,140)
            print("[JOINER] ALERT: "..alert.name.." $"..alert.valStr.."/s  mut:"..tostring(alert.mut).." -> spam x"..tostring(cnt))
            doJoin(alert.jobId,cnt)
        end
    end
end)
