-- ── MAIN POLL LOOP ────────────────────────────────────────────────────────────
task.spawn(function()
    SL.Text="Fetching existing messages..."; SL.TextColor3=C3(80,100,140)
    local first=fetchMsgs()
    for _,m in ipairs(first) do seenIds[m.id]=true end
    print("[JOINER] Synced "..tostring(#first).." existing messages. Now watching for NEW alerts.")
    SL.Text="Watching for alerts...  (every "..FETCH_INTERVAL.."s)"; SL.TextColor3=C3(80,100,140)

    while running do
        task.wait(FETCH_INTERVAL)
        if not running then break end

        SL.Text="Fetching Discord..."; SL.TextColor3=C3(80,120,180)
        local msgs=fetchMsgs()
        local alerts=parseAlerts(msgs)

        if #alerts==0 then
            SL.Text="Watching... ("..tostring(#logEntries).." alerts seen so far)"; SL.TextColor3=C3(55,80,120)
        end

        for _,alert in ipairs(alerts) do
            local timeStr=os.date("%H:%M:%S")
            local entry={
                name=alert.name, valStr=alert.valStr,
                jobId=alert.jobId, players=alert.players, timeStr=timeStr
            }
            table.insert(logEntries,entry)
            addLogRow(entry)

            local cnt=getSpamCount(SpInput)
            SL.Text="NEW ALERT: "..alert.name.."  "..alert.valStr; SL.TextColor3=C3(0,230,150)
            AL.Text=alert.name.."  "..alert.valStr.."  |  "..tostring(alert.players).." players"
            AL.TextColor3=C3(0,220,140)
            print("[JOINER] NEW ALERT: "..alert.name.." "..alert.valStr.." -> spam x"..tostring(cnt))
            doJoin(alert.jobId,cnt)
        end
    end
end)
