task.spawn(function()
    addLog("Joiner started. Fetching every " .. tostring(FETCH_INTERVAL) .. "s")
    addLog("Watching channel: " .. DISCORD_CHANNEL_ID)

    local firstFetch = true
    while running do
        local msgs = fetchDiscordMessages()
        if firstFetch then
            for _, msg in ipairs(msgs) do
                seenMessageIds[msg.id] = true
            end
            firstFetch = false
            addLog("Synced " .. tostring(#msgs) .. " existing messages, watching for NEW alerts.")
        else
            local alerts = parseNewAlerts(msgs)
            for _, alert in ipairs(alerts) do
                local count = getSpamCount()
                addLog("ALERT: " .. alert.name .. " " .. alert.valueStr .. " -> spam x" .. tostring(count))
                StatusLbl.Text = "ALERT: " .. alert.name .. " " .. alert.valueStr
                StatusLbl.TextColor3 = C3(0,230,150)
                spamJoin(alert.jobId, alert.name, alert.valueStr, count)
            end
            if #alerts == 0 then
                addLog("Polled Discord: no new alerts.")
            end
        end
        task.wait(FETCH_INTERVAL)
    end
end)
