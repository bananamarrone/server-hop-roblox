-- ── DISCORD FETCH (executor-compatible: request / http_request / syn.request) ─
local function fetchMsgs()
    local url="https://discord.com/api/v10/channels/"..DISCORD_CHANNEL_ID.."/messages?limit=20"
    local headers={["Authorization"]="Bot "..DISCORD_BOT_TOKEN, ["Content-Type"]="application/json"}
    local body=nil
    local ok=false

    -- try request() first (Ronix, Delta, KRNL, most executors)
    if not ok then
        pcall(function()
            if request then
                local res=request({Url=url, Method="GET", Headers=headers})
                if res and res.Body then body=res.Body; ok=true
                    DBGLbl.Text="fetch OK via request()  status="..tostring(res.StatusCode)
                end
            end
        end)
    end

    -- fallback: http_request()
    if not ok then
        pcall(function()
            if http_request then
                local res=http_request({Url=url, Method="GET", Headers=headers})
                if res and res.Body then body=res.Body; ok=true
                    DBGLbl.Text="fetch OK via http_request()"
                end
            end
        end)
    end

    -- fallback: syn.request()
    if not ok then
        pcall(function()
            if syn and syn.request then
                local res=syn.request({Url=url, Method="GET", Headers=headers})
                if res and res.Body then body=res.Body; ok=true
                    DBGLbl.Text="fetch OK via syn.request()"
                end
            end
        end)
    end

    if not ok or not body then
        DBGLbl.Text="fetch FAILED - no request() in executor?"
        warn("[JOINER] Could not fetch Discord - no compatible request() function found")
        return {}
    end

    local dok,msgs=pcall(function() return HttpService:JSONDecode(body) end)
    if not dok or type(msgs)~="table" then
        DBGLbl.Text="fetch FAILED - JSON decode error"
        warn("[JOINER] Failed to decode Discord response: "..tostring(msgs))
        return {}
    end

    -- Discord returns error object if credentials are wrong
    if msgs.code then
        DBGLbl.Text="Discord error "..tostring(msgs.code)..": "..tostring(msgs.message)
        warn("[JOINER] Discord API error: "..tostring(msgs.code).." "..tostring(msgs.message))
        return {}
    end

    DBGLbl.Text="fetched "..tostring(#msgs).." msgs  "..os.date("%H:%M:%S")
    return msgs
end

-- ── ALERT PARSER ─────────────────────────────────────────────────────────────
-- Field names must match exactly what Scout v8 sends:
--   "Value"      -> e.g. "30.00M/s"
--   "Name"       -> brainrot display name
--   "Players"    -> e.g. "3/8"
--   "Server ID"  -> backtick-wrapped UUID
--   "Raw Value"  -> raw Generation text
local function extractJobId(txt)
    if not txt then return nil end
    return txt:match("([0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+-[0-9a-f]+)")
end

local function parseAlerts(msgs)
    local alerts={}
    for _,msg in ipairs(msgs) do
        if seenIds[msg.id] then break end
        seenIds[msg.id]=true
        if msg.embeds and #msg.embeds>0 then
            for _,emb in ipairs(msg.embeds) do
                if emb.title=="BRAINROT FOUND" and emb.fields then
                    local name,valStr,jobId,players="?","?",nil,0
                    for _,f in ipairs(emb.fields) do
                        local fn=f.name or ""
                        local fv=f.value or ""
                        -- "Value" field from Scout v8: "30.00M/s"
                        if fn=="Value"     then valStr=fv end
                        -- "Name" field: brainrot display name
                        if fn=="Name"      then name=fv end
                        -- "Server ID" field: backtick-wrapped UUID
                        if fn=="Server ID" then jobId=extractJobId(fv) end
                        -- "Players" field: "3/8"
                        if fn=="Players"   then players=tonumber(fv:match("^(%d+)")) or 0 end
                    end
                    if jobId then
                        table.insert(alerts,{name=name,valStr=valStr,jobId=jobId,players=players})
                        print("[JOINER] Parsed alert: "..name.." "..valStr.." srv="..jobId)
                    else
                        print("[JOINER] Embed had no Server ID - skipping")
                    end
                end
            end
        end
    end
    return alerts
end

