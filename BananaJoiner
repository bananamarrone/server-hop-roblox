            SL.Text="ALERT: "..alert.name.."  "..alert.valStr; SL.TextColor3=C3(0,230,150)
            AL.Text=alert.name.."  "..alert.valStr; AL.TextColor3=C3(0,220,140)
            doJoin(alert.jobId,cnt)
        end
    end)
end)

