local Cfg = {targetValue=30e6, blacklist={}, whitelist={}, wasHunting=false}

local function saveCfg()
    local ok, enc = pcall(function() return HttpService:JSONEncode(Cfg) end)
    if not ok then log("JSON encode error"); return end
    local wrote = safeWrite(SETTINGS_FILE, enc)
    if wrote then
        log("Settings saved OK")
    else
        log("Settings save FAILED (writefile unavailable)")
    end
end

local function loadCfg()
    local raw = safeRead(SETTINGS_FILE)
    if not raw then log("No settings file, using defaults"); return end
    local ok, d = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok or type(d) ~= "table" then log("Settings decode failed"); return end
    if type(d.targetValue) == "number" and d.targetValue > 0 then Cfg.targetValue = d.targetValue end
    if type(d.blacklist)   == "table"  then Cfg.blacklist   = d.blacklist  end
    if type(d.whitelist)   == "table"  then Cfg.whitelist   = d.whitelist  end
    if type(d.wasHunting)  == "boolean" then Cfg.wasHunting = d.wasHunting end
    log("Settings loaded: target=$" .. Cfg.targetValue .. " wasHunting=" .. tostring(Cfg.wasHunting))
end

