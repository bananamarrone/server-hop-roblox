-- ============================================================
-- LOGIC
-- ============================================================
local hunting  = false
local hopCount = 0

local function setStatus(txt, r, g, b)
    StatL.Text       = txt
    StatL.TextColor3 = C3(r, g, b)
end

local function isWanted(name)
    local nl = name:lower()
    if next(WLset) ~= nil then return WLset[nl] == true end
    if BLset[nl] then return false end
    return true
end

local function stopHunt()
    hunting        = false
    Cfg.wasHunting = false
    saveCfg()
    StartBtn.Text       = "START HUNTING"
    StartBtn.TextColor3 = C3(0, 9, 5)
    StartGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, C3(0,  208, 140)),
        ColorSequenceKeypoint.new(1, C3(0,  168, 255))
    })
    setStatus("STOPPED", 48, 62, 88)
    setBar(0)
    Dot.BackgroundColor3 = C3(30, 48, 78)
end

local function doHop()
    hopCount = hopCount + 1
    HopL.Text = "HOPS: " .. hopCount
    local oldJob = game.JobId
    queueSelf()
    log("Hop #" .. hopCount .. " | current=" .. oldJob:sub(1,8))
    -- keep retrying until JobId actually changes
    local attempts = 0
    while hunting and game.JobId == oldJob and attempts < 12 do
        attempts = attempts + 1
        pcall(function() TeleportService:Teleport(PlaceId, LP) end)
        local t0 = tick()
        while hunting and tick()-t0 < 4 and game.JobId == oldJob do
            task.wait(0.2)
        end
    end
    if game.JobId == oldJob then
        log("Hop failed after " .. attempts .. " attempts - loop will retry")
        task.wait(2)
    else
        log("Hopped to " .. game.JobId:sub(1,8))
    end
end

local function startHunt()
    if targetValue <= 0 then
        setStatus("SET A TARGET VALUE FIRST", 198, 50, 50)
        TweenService:Create(IStroke, TI(0.12), {Color=C3(185, 36, 36)}):Play()
        task.delay(1.2, function() IStroke.Color = C3(0, 118, 72) end)
        return
    end
    hunting        = true
    Cfg.wasHunting = true
    saveCfg()
    StartBtn.Text       = "STOP HUNTING"
    StartBtn.TextColor3 = C3(255, 198, 198)
    StartGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, C3(200, 30, 30)),
        ColorSequenceKeypoint.new(1, C3(145, 14, 60))
    })

    task.spawn(function()
        while hunting do

            -- STEP 1: wait for animals to appear
            local t0     = tick()
            local loaded = false
            while hunting and tick()-t0 < LOAD_WAIT do
                if hasAnimals() then loaded = true; break end
                local rem = math.ceil(LOAD_WAIT - (tick()-t0))
                setStatus("Loading... (" .. rem .. "s)", 40, 68, 118)
                setBar((tick()-t0) / LOAD_WAIT)
                task.wait(0.25)
            end
            if not hunting then break end

            -- STEP 2: scan (max SCAN_MAX seconds, stops early if value settles)
            local bv, bn, br = -1, "?", ""
            local lastImp   = tick()
            local scanStart = tick()

            if loaded then
                while hunting and tick()-scanStart < SCAN_MAX do
                    local v, n, r = scanBest()
                    if v > bv then bv=v; bn=n; br=r; lastImp=tick() end
                    local el = tick() - scanStart
                    setBar(el / SCAN_MAX)
                    if bv > 0 then
                        setStatus("$" .. fmtVal(bv) .. "/s  scanning...", 0, 155, 98)
                        BestL.Text       = bn .. "  " .. br
                        BestL.TextColor3 = C3(44, 74, 118)
                    else
                        setStatus("Scanning...", 0, 108, 72)
                    end
                    if bv > 0 and tick()-lastImp > SCAN_SETTLE and el > 0.5 then break end
                    task.wait(0.15)
                end
            else
                setStatus("Nothing loaded - hopping", 72, 85, 115)
            end
            if not hunting then break end

            setBar(1)
            log("Scan done: " .. fmtVal(bv) .. "/s  " .. bn)

            -- STEP 3: decide
            local wanted = isWanted(bn)

            if bv >= targetValue and wanted then
                setStatus("FOUND!  " .. bn .. "  " .. br, 0, 245, 148)
                BestL.Text       = "STAYING:  " .. bn .. "  " .. br
                BestL.TextColor3 = C3(0, 205, 128)
                setBar(1)
                playAlert()
                notify("Banana Found!", "$" .. fmtVal(bv) .. "/s  -  " .. bn)
                for _ = 1, 6 do
                    TweenService:Create(CardBorder, TI(0.1), {Color=C3(0, 245, 138)}):Play()
                    task.wait(0.13)
                    TweenService:Create(CardBorder, TI(0.1), {Color=C3(18, 30, 52)}):Play()
                    task.wait(0.13)
                end
                stopHunt()
                break
            end

            if bv >= targetValue and not wanted then
                setStatus("SKIP (blacklisted): " .. bn, 118, 72, 34)
                BestL.Text       = "skipped: " .. bn
                BestL.TextColor3 = C3(95, 60, 26)
            end

            if bv < targetValue then
                if bv > 0 then
                    setStatus("$" .. fmtVal(bv) .. "/s  too low - hopping", 48, 88, 158)
                    BestL.Text       = "last: " .. bn .. "  " .. br
                    BestL.TextColor3 = C3(28, 44, 72)
                else
                    setStatus("Nothing found - hopping", 44, 66, 112)
                    BestL.Text       = "last seen: -"
                    BestL.TextColor3 = C3(24, 38, 65)
                end
            end

            doHop()
        end
    end)
end

