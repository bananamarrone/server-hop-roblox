-- ================================================================
local animalCache = {}

local function rebuildCache()
    animalCache = {}
    local ok, desc = pcall(function() return workspace:GetDescendants() end)
    if not ok or not desc then return end
    for _, o in next, desc do
        if o.Name == "AnimalOverhead" then animalCache[o] = true end
    end
end

pcall(function()
    workspace.DescendantAdded:Connect(function(o)
        if o.Name == "AnimalOverhead" then animalCache[o] = true end
    end)
    workspace.DescendantRemoving:Connect(function(o)
        if o.Name == "AnimalOverhead" then animalCache[o] = nil end
    end)
end)

rebuildCache()

local function scanBest()
    local bv, bn, br = -1, "?", ""
    for o in next, animalCache do
        if o and o.Parent then
            local g = o:FindFirstChild("Generation")
            if g then
                local ok2, v = pcall(parseValue, g.Text)
                if ok2 and v > bv then
                    bv = v; br = g.Text
                    local dn = o:FindFirstChild("DisplayName")
                    bn = (dn and dn.Text ~= "") and dn.Text or "?"
                end
            end
        else
            animalCache[o] = nil
        end
    end
    return bv, bn, br
end

local function hasAnimals()
    for o in next, animalCache do
        if o and o.Parent then return true end
        animalCache[o] = nil
    end
    return false
end

