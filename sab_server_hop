local VISITED_FILE = "BSH_visited.json"

-- Load visited IDs from file. Returns table of {[jobId]=true}
local function loadV()
    local ok1, ex = pcall(isfile, VISITED_FILE)
    if not ok1 or not ex then return {} end
    local ok2, raw = pcall(readfile, VISITED_FILE)
    if not ok2 or not raw or raw == "" then return {} end
    local ok3, t = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok3 or type(t) ~= "table" then return {} end
    -- strip __cursor key, return only IDs
    local out = {}
    for k, v in pairs(t) do
        if k ~= "__cursor" then out[k] = true end
    end
    return out
end

-- Save visited IDs + cursor to file
local function saveV(ids, cursor)
    local payload = {}
    for k in pairs(ids) do payload[k] = true end
    payload["__cursor"] = cursor or ""
    local ok, enc = pcall(HttpService.JSONEncode, HttpService, payload)
    if not ok then return end
    pcall(writefile, VISITED_FILE, enc)
end

-- Get cursor from file
local function loadCursor()
    local ok1, ex = pcall(isfile, VISITED_FILE)
    if not ok1 or not ex then return "" end
    local ok2, raw = pcall(readfile, VISITED_FILE)
    if not ok2 or not raw or raw == "" then return "" end
    local ok3, t = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok3 or type(t) ~= "table" then return "" end
    local cur = t["__cursor"]
    if type(cur) == "string" and cur ~= "null" and cur ~= "" then return cur end
    return ""
end

local function getServers(cursor)
    local url = ("https://games.roblox.com/v1/games/%d/servers/Public"
        .. "?sortOrder=Asc&excludeFullGames=true&limit=25"):format(PlaceId)
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. cursor
    end
    local ok, body = pcall(game.HttpGet, game, url)
    if not ok or not body then return nil, nil end
    local ok2, res = pcall(HttpService.JSONDecode, HttpService, body)
    if not ok2 or type(res) ~= "table" or type(res.data) ~= "table" then return nil, nil end
    local next = res.nextPageCursor
    if type(next) ~= "string" or next == "null" then next = "" end
    return res.data, next
end

local function doTeleport()
    queueSelf()
    task.wait(0.15)

    -- load state from file
    local visited = loadV()
    local cursor  = loadCursor()
    visited[game.JobId] = true  -- always mark current as visited

    log("doTeleport: visited=" .. (function() local n=0; for _ in pairs(visited) do n=n+1 end; return n end)()
        .. " cursor=" .. (cursor == "" and "START" or cursor:sub(1,12)))

    local pick       = nil
    local newCursor  = cursor
    local tries      = 0
    local didReset   = false

    -- walk pages until we find an unvisited server
    while tries < 30 do
        tries = tries + 1
        local data, nextCur = getServers(newCursor)

        if not data then
            log("HTTP fail on try " .. tries)
            task.wait(0.5)
            -- retry same cursor
        else
            log("Try " .. tries .. ": got " .. #data .. " servers")
            for _, srv in ipairs(data) do
                if type(srv.id) == "string"
                and srv.id ~= game.JobId
                and not visited[srv.id]
                and type(srv.playing) == "number"
                and srv.playing >= MIN_PLAYERS then
                    pick      = srv
                    newCursor = nextCur  -- save cursor AFTER this page
                    break
                end
            end
            if pick then break end

            -- no pick on this page
            if nextCur == "" then
                -- end of list
                if didReset then
                    -- already reset once, just pick anything not current
                    for _, srv in ipairs(data) do
                        if type(srv.id) == "string" and srv.id ~= game.JobId then
                            pick      = srv
                            newCursor = ""
                            break
                        end
                    end
                    if pick then break end
                    log("No servers at all")
                    TeleportService:Teleport(PlaceId, LP)
                    return
                end
                -- reset visited list and start over from page 1
                log("End of list - resetting visited")
                visited   = {}
                visited[game.JobId] = true
                newCursor = ""
                didReset  = true
            else
                newCursor = nextCur
            end
        end
        task.wait(0.05)
    end

    if not pick then
        log("Gave up after " .. tries .. " tries - plain Teleport")
        saveV(visited, "")
        TeleportService:Teleport(PlaceId, LP)
        return
    end

    -- mark picked server as visited and save EVERYTHING before teleporting
    visited[pick.id] = true
    saveV(visited, newCursor)

    log("HOP -> " .. pick.id .. " | " .. (pick.playing or 0) .. "p | tries=" .. tries)

    TeleportService:TeleportToPlaceInstance(PlaceId, pick.id, LP)

    -- fallback if didn't fire in 10s
    task.wait(10)
    TeleportService:Teleport(PlaceId, LP)
end

