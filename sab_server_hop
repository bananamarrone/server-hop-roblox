    end)
end)

local guiVisible = true
local function toggleGui()
    guiVisible      = not guiVisible
    Card.Visible    = guiVisible
    GlowA.Visible   = guiVisible
    GlowB.Visible   = guiVisible
end

HideBtn.MouseButton1Click:Connect(toggleGui)

-- pulsing dot animation
task.spawn(function()
    local t = 0
    while true do
        t = t + 0.05
        local a = (math.sin(t * 2.8) + 1) / 2
        if hunting then
            Dot.BackgroundColor3 = C3(0, math.floor(160+a*95), math.floor(84+a*88))
            HopStroke.Color      = C3(0, math.floor(92+a*82),  math.floor(52+a*56))
        else
            Dot.BackgroundColor3 = C3(26, 42, 70)
            HopStroke.Color      = C3(0, 112, 68)
        end
        task.wait(0.05)
    end
end)

-- ================================================================
-- KEYBINDS  (skip on mobile, skip if typing in a TextBox)
-- ================================================================
if not isMobile then
    UserInputService.InputBegan:Connect(function(i, gameProcessed)
        if gameProcessed then return end
        -- don't fire keybinds while user is typing
        local focused = UserInputService:GetFocusedTextBox()
        if focused then return end

        local kc = i.KeyCode.Name
        if kc == KB_TOGGLE then
            if hunting then stopHunt() else startHunt() end
        end
        if kc == KB_HOP then
            ForceBtn.MouseButton1Click:Fire()
        end
        if kc == KB_HIDE then
            toggleGui()
        end
    end)
end

-- ================================================================
-- STARTUP
-- ================================================================
task.delay(0.5, function()
    showSaveResult(saveCfg())
end)

-- Only auto-start if we arrived here via a previous hop (wasHunting flag)
-- NOT on first-ever execution. If wasHunting was never set, it defaults
-- to false, so a fresh execute will NOT auto-start.
-- Auto-resume: check BOTH getgenv (fast, same session) and file (survives teleport)
-- _loaded_wasHunting comes from the state file written just before teleporting
local shouldAutoStart = (getgenv().BSH_WAS_HUNTING == true) or (_loaded_wasHunting == true)
if shouldAutoStart then
    log("Resuming hunt after teleport (hops so far: " .. hopCount .. ")")
    task.delay(1.5, startHunt)
else
    log("Fresh execute - not auto-starting")
end

log("v20 loaded | target=$" .. fmtVal(Cfg.targetValue) .. " | hops: " .. hopCount)
