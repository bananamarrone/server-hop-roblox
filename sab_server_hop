local function safeWrite(f, d)
    return pcall(function() writefile(f, d) end)
end

local function safeRead(f)
    local exists = false
    pcall(function() exists = isfile(f) end)
    if not exists then return nil end
    local ok, d = pcall(function() return readfile(f) end)
    return ok and d or nil
end

