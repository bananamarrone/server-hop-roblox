-- ============================================================
-- VALUE PARSER
-- ============================================================
local function parseValue(t)
    if not t then return 0 end
    local n, s = t:match("%$([%d%.]+)%s*([kKmMbBtT]?)")
    n = tonumber(n) or 0
    if s == "k" or s == "K" then n = n * 1e3  end
    if s == "m" or s == "M" then n = n * 1e6  end
    if s == "b" or s == "B" then n = n * 1e9  end
    if s == "t" or s == "T" then n = n * 1e12 end
    return n
end

local function fmtVal(n)
    if not n or n <= 0 then return "0" end
    if n >= 1e12 then return string.format("%.2fT", n/1e12) end
    if n >= 1e9  then return string.format("%.2fB", n/1e9)  end
    if n >= 1e6  then return string.format("%.2fM", n/1e6)  end
    if n >= 1e3  then return string.format("%.1fK", n/1e3)  end
    return tostring(math.floor(n))
end

local function parseInput(txt)
    if not txt or txt == "" then return 0 end
    local n, s = txt:lower():gsub("%s",""):match("^([%d%.]+)([kmbt]?)$")
    n = tonumber(n)
    if not n then return 0 end
    if s == "k" then n = n * 1e3  end
    if s == "m" then n = n * 1e6  end
    if s == "b" then n = n * 1e9  end
    if s == "t" then n = n * 1e12 end
    return n
end

local function valToStr(n)
    if n >= 1e9  then return string.format("%.2fb", n/1e9) end
    if n >= 1e6  then return string.format("%.0fm",  n/1e6) end
    if n >= 1e3  then return string.format("%.0fk",  n/1e3) end
    return tostring(math.floor(n))
end

