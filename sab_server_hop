local function sendWebhook(val, name, rawText, jobId)
    local valStr  = fmtVal(val) .. "/s"
    local joinCmd = string.format(
        "game:GetService('TeleportService'):TeleportToPlaceInstance(%d,'%s')", PlaceId, jobId)
    local ok, body = pcall(function()
        return HttpService:JSONEncode({
            username = "Banana Server Hop",
            embeds   = {{
                title  = "SERVER FOUND",
                color  = 3461080,
                fields = {
                    {name="Value",        value=valStr,                        inline=true},
                    {name="Name",         value=name,                          inline=true},
                    {name="Raw",          value=rawText,                       inline=false},
                    {name="Server ID",    value="`"..jobId.."`",               inline=false},
                    {name="Join Command", value="```lua\n"..joinCmd.."\n```",  inline=false},
                },
                footer = {text = "Banana Server Hop v20"}
            }}
        })
    end)
    if not ok then return end
    local h = {["Content-Type"] = "application/json"}
    local payload = {Url=WEBHOOK_URL, Method="POST", Headers=h, Body=body}
    -- try every known executor request function
    pcall(function() request(payload) end)
    pcall(function() http_request(payload) end)
    local syn = rawget(_G, "syn")
    if syn and syn.request then pcall(function() syn.request(payload) end) end
    local http = rawget(_G, "http")
    if http and http.request then pcall(function() http.request(payload) end) end
end

