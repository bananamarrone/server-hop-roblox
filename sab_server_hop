-- ============================================================
-- FILE I/O  (safe for all executors)
-- ============================================================
local _isfile    = rawget(_G, "isfile")
local _readfile  = rawget(_G, "readfile")
local _writefile = rawget(_G, "writefile")

local function safeRead(f)
    if not _isfile or not _readfile then return nil end
    local ok, ex = pcall(_isfile, f)
    if not ok or not ex then return nil end
    local ok2, d = pcall(_readfile, f)
    return ok2 and d or nil
end

local function safeWrite(f, d)
    if not _writefile then return false end
    -- some executors need the folder to exist; try a pre-touch
    pcall(_writefile, f, d)
    -- verify write succeeded
    local ok, ex = pcall(function()
        if _isfile then return _isfile(f) end
        return false
    end)
    return ok and ex
end

