-- ================================================================
-- LOGIC
-- ================================================================
local hunting  = false
hopCount = _loaded_hopCount
getgenv().BSH_HOP_COUNT = hopCount
HopL.Text = "HOPS: " .. hopCount

local function setStatus(txt, r, g, b)
    StatL.Text       = txt
    StatL.TextColor3 = C3(r, g, b)
end

local function getAnimalTarget(name)
    local nl = name:lower()
    for k, v in pairs(Cfg.customTargets) do
        if k:lower() == nl then return v end
    end
    return targetValue
end

local function isWanted(name)
    local nl = name:lower()
    if next(WLset) ~= nil then return WLset[nl] == true end
    if BLset[nl] then return false end
    return true
end

local function setGreenStart()
    StartGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, C3(0,  208, 140)),
        ColorSequenceKeypoint.new(1, C3(0,  168, 255))
    })
    StartBtn.Text       = "START HUNTING"
    StartBtn.TextColor3 = C3(0, 8, 5)
end

local function setRedStop()
    StartGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, C3(200, 28, 28)),
        ColorSequenceKeypoint.new(1, C3(140, 12, 58))
    })
    StartBtn.Text       = "STOP HUNTING"
    StartBtn.TextColor3 = C3(255, 192, 192)
end

local function stopHunt()
    hunting             = false
    Cfg.wasHunting      = false
    getgenv().BSH_WAS_HUNTING = false
    -- write false to file so fresh launch won't auto-start
    saveState()
    setGreenStart()
    setStatus("STOPPED", 42, 58, 85)
    setBar(0)
    Dot.BackgroundColor3 = C3(26, 42, 70)
end

local function doHop()
    hopCount = hopCount + 1
    getgenv().BSH_HOP_COUNT = hopCount
    HopL.Text = "HOPS: " .. hopCount
    log("Hop #" .. hopCount)
    doTeleport()
    local t0 = tick()
    while hunting and tick() - t0 < 5 do task.wait(0.1) end
end

local function startHunt()
    if targetValue <= 0 then
        setStatus("SET A TARGET VALUE FIRST", 192, 46, 46)
        TweenService:Create(IStroke, TI(0.12), {Color=C3(185, 34, 34)}):Play()
        task.delay(1.2, function() IStroke.Color = C3(0, 112, 68) end)
        return
    end

    hunting                   = true
    Cfg.wasHunting            = true
    getgenv().BSH_WAS_HUNTING = true
    saveCfg()
    setRedStop()

    task.spawn(function()
        while hunting do

            -- STEP 1: wait for animals
            rebuildCache()
            local t0     = tick()
            local loaded = false
            while hunting and tick() - t0 < LOAD_WAIT do
                if hasAnimals() then loaded = true; break end
                setStatus("Waiting for server... (" .. math.ceil(LOAD_WAIT - (tick()-t0)) .. "s)", 36, 62, 108)
                setBar((tick() - t0) / LOAD_WAIT)
                task.wait(0.3)
            end
            if not hunting then break end

            -- STEP 2: scan
            local bv, bn, br = -1, "?", ""
            local lastImp    = tick()
            local scanStart  = tick()

            if loaded then
                while hunting and tick() - scanStart < SCAN_MAX do
                    local v, n, r = scanBest()
                    if v > bv then bv=v; bn=n; br=r; lastImp=tick() end
                    local el = tick() - scanStart
                    setBar(el / SCAN_MAX)
                    if bv > 0 then
                        setStatus("$" .. fmtVal(bv) .. "/s  scanning...", 0, 150, 94)
                        BestL.Text       = bn .. "  " .. br
                        BestL.TextColor3 = C3(40, 70, 112)
                    else
                        setStatus("Scanning...", 0, 102, 68)
                    end
                    if bv > 0 and tick() - lastImp > SCAN_SETTLE and el > 0.4 then break end
                    task.wait(0.25)
                end
            else
                setStatus("Nothing loaded - hopping", 68, 80, 110)
            end

            if not hunting then break end

            setBar(1)
            local numP = #Players:GetPlayers()
            if bv > 0 then pushHistory(bv, bn, numP); refreshHistory() end
            log("Scan: " .. fmtVal(bv) .. "/s  " .. bn)

            local animalTarget = getAnimalTarget(bn)
            local wanted       = isWanted(bn)

            if bv >= animalTarget and wanted then
                setStatus("FOUND!  " .. bn .. "  " .. br, 0, 240, 144)
                BestL.Text       = "STAYING:  " .. bn .. "  " .. br
                BestL.TextColor3 = C3(0, 200, 124)
                setBar(1)
                playAlert()
                notify("Banana Found!", "$" .. fmtVal(bv) .. "/s  " .. bn)
                if bv >= 30e6 then
                    task.spawn(function() sendWebhook(bv, bn, br, game.JobId) end)
                end
                for _ = 1, 7 do
                    TweenService:Create(CardBorder, TI(0.1), {Color=C3(0, 240, 134)}):Play()
                    task.wait(0.12)
                    TweenService:Create(CardBorder, TI(0.1), {Color=C3(14, 24, 44)}):Play()
                    task.wait(0.12)
                end
                stopHunt()
                break
            end

            if bv >= animalTarget and not wanted then
                setStatus("SKIP (blacklisted): " .. bn, 112, 68, 30)
                BestL.Text       = "skipped: " .. bn
                BestL.TextColor3 = C3(90, 56, 22)
            end

            if bv < animalTarget then
                if bv > 0 then
                    setStatus("$" .. fmtVal(bv) .. "/s  too low - hopping", 44, 82, 152)
                    BestL.Text       = "last: " .. bn .. "  " .. br
                    BestL.TextColor3 = C3(24, 40, 68)
                else
                    setStatus("Nothing found - hopping", 40, 62, 106)
                    BestL.Text       = "last seen: -"
                    BestL.TextColor3 = C3(20, 34, 60)
                end
            end

            doHop()
        end
    end)
end

